<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <data>
        <!-- DataBinding 变量可以在这里定义 -->
    </data>

<ScrollView
    android:layout_width="fill_parent"
    android:layout_height="fill_parent" >
	<LinearLayout 
    android:layout_width="fill_parent"
    android:layout_height="match_parent"
    android:orientation="vertical" >
	<LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">

           <TextView
                    android:layout_width="0dip"
                    android:layout_height="wrap_content"
                    android:gravity="right"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:text="@string/info_result" />

                <TextView
                    android:id="@+id/rw_result"
                    android:layout_weight="2"
                    android:layout_width="0dip"
                    android:layout_gravity="center"
                    android:textSize="20dp"
                    android:textColor="#cc0000"
                    android:gravity="center"
                    android:layout_height="@dimen/rm_6c_et_height"/>
        </LinearLayout>
        
	    <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                 >
            <LinearLayout
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="0dip"
                    android:layout_height="wrap_content"
                    android:gravity="right"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:text="@string/txtepc" />

                <TextView
                    android:id="@+id/epc_text"
                    android:layout_width="0dip"
                    android:layout_height="wrap_content"
                    android:gravity="left"
                    android:layout_gravity="center"
                    android:layout_weight="2"
                    android:text="" />


            </LinearLayout>

            <LinearLayout
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="0dip"
                    android:layout_height="wrap_content"
                    android:gravity="right"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:text="@string/tid" />

                <TextView
                    android:id="@+id/tid_text"
                    android:layout_width="0dip"
                    android:layout_height="wrap_content"
                    android:gravity="left"
                    android:layout_gravity="center"
                    android:layout_weight="2"
                    android:text="" />
            </LinearLayout>
            </LinearLayout>
               
        </LinearLayout>

        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="0dip"
                android:layout_height="wrap_content"
                android:gravity="right"
                android:layout_gravity="center"
                android:layout_weight="1"
                android:text="@string/pwdstr" />
            <EditText
                android:id="@+id/et_pwd"
                android:layout_width="0dip"
                android:layout_height="@dimen/rm_6c_et_height"
                android:layout_weight="2"
                android:hint="00000000"
                android:gravity="left" />

        </LinearLayout>
        
	  <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">

           <TextView
                    android:layout_width="0dip"
                    android:layout_height="wrap_content"
                    android:gravity="right"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:text="@string/bankid" />
			<Spinner
                android:id="@+id/mem_spinner"
                android:layout_width="0dip"
                android:layout_height="@dimen/rm_6c_et_height"
                android:layout_weight="2"
                android:gravity="left" />
               
        </LinearLayout>
        
	  <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">

           <TextView
                    android:layout_width="0dip"
                    android:layout_height="wrap_content"
                    android:gravity="right"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:text="@string/memptr" />
			<EditText
                android:id="@+id/et_wordptr"
                android:layout_width="0dip"
                android:layout_height="@dimen/rm_6c_et_height"
                android:layout_weight="2"
                android:inputType="numberSigned"
                android:text="0"
                android:gravity="left" />
               
        </LinearLayout>
        
	  <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">

           <TextView
                    android:layout_width="0dip"
                    android:layout_height="wrap_content"
                    android:gravity="right"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:text="@string/memlen" />
			<EditText
                android:id="@+id/et_length"
                android:layout_width="0dip"
                android:layout_height="@dimen/rm_6c_et_height"
                android:layout_weight="2"
                android:inputType="numberSigned"
                android:text="6"
                android:gravity="left" />
               
        </LinearLayout>
        
	  

        
	  <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">

           <TextView
                    android:layout_width="0dip"
                    android:layout_height="wrap_content"
                    android:gravity="right"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:text="@string/writestr" />
			<EditText
                android:id="@+id/et_content_6c"
                android:layout_width="0dip"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:text=""
                android:inputType="textMultiLine"
                android:gravity="left" />
               
        </LinearLayout>
        
	   <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">

           <TextView
                    android:layout_width="0dip"
                    android:layout_height="wrap_content"
                    android:gravity="right"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:text="@string/readstr" />
			<EditText
                android:id="@+id/et_read_6c"
                android:layout_width="0dip"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:text=""
                android:inputType="textMultiLine"
                android:singleLine="false"
                android:gravity="left" />
               
        </LinearLayout>
        
	    <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">

            <Button
                android:id="@+id/button_read_6c"
                android:layout_width="0dip"
                android:layout_height="@dimen/button_height"
                android:layout_gravity="center_horizontal"
                android:layout_weight="1"
                android:background="@drawable/color_button_selector"
                android:textColor="@color/white"
                android:layout_marginLeft="5dp"
                android:text="@string/butnread" />

            <Button
                android:id="@+id/button_write_6c"
                android:layout_width="0dip"
                android:layout_height="@dimen/button_height"
                android:layout_gravity="center_horizontal"
                android:layout_weight="1"
                android:background="@drawable/color_button_selector"
                android:textColor="@color/white"
                android:layout_marginLeft="5dp"
                android:text="@string/butnwrite" />
            <Button
                android:id="@+id/button_write_epc"
                android:layout_width="0dip"
                android:layout_height="@dimen/button_height"
                android:layout_gravity="center_horizontal"
                android:layout_weight="1"
                android:background="@drawable/color_button_selector"
                android:textColor="@color/white"
                android:layout_marginLeft="5dp"
                android:text="@string/butnwriteepc" />

            <Button
                android:id="@+id/button_led"
                android:layout_width="0dip"
                android:layout_height="33dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginLeft="5dp"
                android:layout_weight="1"
                android:visibility="gone"
                android:background="@drawable/color_button_selector"
                android:text="@string/StrLED"
                android:textColor="@color/white" />

        </LinearLayout>
        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginTop="5dp">

            <Button
                android:id="@+id/button_erase"
                android:layout_width="0dip"
                android:layout_height="@dimen/button_height"
                android:layout_gravity="center_horizontal"
                android:layout_weight="1"
                android:background="@drawable/color_button_selector"
                android:textColor="@color/white"
                android:layout_marginLeft="5dp"
                android:text="@string/btn_erase" />

            <Button
                android:id="@+id/button_001"
                android:layout_width="0dip"
                android:layout_height="@dimen/button_height"
                android:layout_gravity="center_horizontal"
                android:layout_weight="1"
                android:visibility="invisible"
                android:background="@drawable/color_button_selector"
                android:textColor="@color/white"
                android:layout_marginLeft="5dp"
                android:text="@string/butnwrite" />
            <Button
                android:id="@+id/button_002"
                android:layout_width="0dip"
                android:layout_height="@dimen/button_height"
                android:layout_gravity="center_horizontal"
                android:layout_weight="1"
                android:background="@drawable/color_button_selector"
                android:textColor="@color/white"
                android:layout_marginLeft="5dp"
                android:visibility="invisible"
                android:text="@string/butnwriteepc" />

            <Button
                android:id="@+id/button_003"
                android:layout_width="0dip"
                android:layout_height="@dimen/button_height"
                android:visibility="invisible"
                android:layout_gravity="center_horizontal"
                android:layout_weight="1"
                android:background="@drawable/color_button_selector"
                android:textColor="@color/white"
                android:layout_marginLeft="5dp"
                android:text="@string/StrLED" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="0dip"
                android:layout_height="wrap_content"
                android:gravity="right"
                android:layout_gravity="center"
                android:layout_weight="1"
                android:text="@string/tvLockMem" />
            <Spinner
                android:id="@+id/lockmem_spinner"
                android:layout_width="0dip"
                android:layout_height="@dimen/rm_6c_et_height"
                android:layout_weight="2"
                android:gravity="left" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="0dip"
                android:layout_height="wrap_content"
                android:gravity="right"
                android:layout_gravity="center"
                android:layout_weight="1"
                android:text="@string/tvLockType" />
            <Spinner
                android:id="@+id/locktype_spinner"
                android:layout_width="0dip"
                android:layout_height="@dimen/rm_6c_et_height"
                android:layout_weight="2"
                android:gravity="left" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">

            <CheckBox
                android:id="@+id/checku9"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="U9" />

            <Button
                android:id="@+id/button_lock"
                android:layout_width="0dip"
                android:layout_height="@dimen/button_height"
                android:layout_gravity="center_horizontal"
                android:layout_weight="2"
                android:background="@drawable/color_button_selector"
                android:textColor="@color/white"
                android:layout_marginLeft="5dp"
                android:text="@string/btlock" />

        </LinearLayout>


        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="0dip"
                android:layout_height="wrap_content"
                android:gravity="right"
                android:layout_gravity="center"
                android:layout_weight="1"
                android:text="@string/tvKillPwd" />
            <EditText
                android:id="@+id/et_kwd"
                android:layout_width="0dip"
                android:layout_height="@dimen/rm_6c_et_height"
                android:layout_weight="2"
                android:text="12345678"
                android:gravity="left" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">

            <Button
                android:id="@+id/button_kill"
                android:layout_width="0dip"
                android:layout_height="@dimen/button_height"
                android:layout_gravity="center_horizontal"
                android:layout_weight="1"
                android:background="@drawable/color_button_selector"
                android:textColor="@color/white"
                android:layout_marginLeft="5dp"
                android:text="@string/btKill" />

        </LinearLayout>



        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="5dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#cc0000"
                android:text="@string/noteStr" />

        </LinearLayout>
   
</LinearLayout>
</ScrollView>
</layout>