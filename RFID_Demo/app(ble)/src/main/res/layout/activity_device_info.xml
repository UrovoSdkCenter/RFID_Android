<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <data>
        <!-- DataBinding 变量可以在这里定义 -->
    </data>

<LinearLayout
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:keepScreenOn="true"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">

        <TextView
            android:layout_width="0dip"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_weight="1"
            android:gravity="right"
            android:text="@string/info_result" />

        <TextView
            android:id="@+id/param_result"
            android:layout_width="0dip"
            android:layout_height="@dimen/rm_6c_et_height"
            android:layout_gravity="center"
            android:layout_weight="2"
            android:gravity="center"
            android:textColor="#cc0000"
            android:textSize="20dp" />
    </LinearLayout>


    <ScrollView
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dip"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">


                <TextView
                    android:layout_width="fill_parent"
                    android:layout_height="5dp" />

                <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/battery_ischange"
                        android:layout_width="0dip"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:textStyle="bold"
                        android:text="@string/battery_ischange"
                        />

                    <TextView
                        android:id="@+id/battery_level"
                        android:layout_width="0dip"
                        android:layout_height="@dimen/rm_6c_et_height"
                        android:layout_gravity="center"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:textStyle="bold"
                        android:text="@string/battery_level"
                        />
                </LinearLayout>




                <TextView
                    android:layout_width="fill_parent"
                    android:layout_height="5dp" />



                <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="0dip"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_weight="1"
                        android:gravity="right"
                        android:text="@string/mcu_ver_" />

                    <TextView
                        android:id="@+id/txt_ver_mcu"
                        android:layout_width="0dip"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_weight="2"
                        android:gravity="center"
                        android:text="" />

                    <Button
                        android:id="@+id/bt_ReadVerMcu"
                        android:layout_width="0dip"
                        android:layout_height="40dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginLeft="5dp"
                        android:layout_weight="1"
                        android:background="@drawable/color_button_selector"
                        android:text="@string/getstr"
                        android:textColor="@color/white" />
                </LinearLayout>

                <TextView
                    android:layout_width="fill_parent"
                    android:layout_height="5dp" />

                <LinearLayout
                    android:id="@+id/line002"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="0dip"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_weight="1"
                        android:gravity="right"
                        android:text="@string/ble_ver" />

                    <TextView
                        android:id="@+id/txt_ver_ble"
                        android:layout_width="0dip"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_weight="2"
                        android:gravity="center"
                        android:text="" />

                    <Button
                        android:id="@+id/bt_ReadVerBle"
                        android:layout_width="0dip"
                        android:layout_height="40dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginLeft="5dp"
                        android:layout_weight="1"
                        android:background="@drawable/color_button_selector"
                        android:text="@string/getstr"
                        android:textColor="@color/white" />
                </LinearLayout>

                <TextView
                    android:layout_width="fill_parent"
                    android:layout_height="5dp" />

                <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="0dip"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_weight="1"
                        android:gravity="right"
                        android:text="@string/rfid_mcu_" />

                    <TextView
                        android:id="@+id/txt_ver_rfid"
                        android:layout_width="0dip"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_weight="2"
                        android:gravity="center"
                        android:text="" />

                    <Button
                        android:id="@+id/bt_ReadVerRfid"
                        android:layout_width="0dip"
                        android:layout_height="40dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginLeft="5dp"
                        android:layout_weight="1"
                        android:background="@drawable/color_button_selector"
                        android:text="@string/getstr"
                        android:textColor="@color/white" />
                </LinearLayout>

                <TextView
                    android:layout_width="fill_parent"
                    android:layout_height="5dp" />

                <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="0dip"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_weight="1"
                        android:gravity="right"
                        android:text="@string/scan_ver_" />

                    <TextView
                        android:id="@+id/txt_scan_version"
                        android:layout_width="0dip"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_weight="2"
                        android:gravity="center"
                        android:text="" />

                    <Button
                        android:id="@+id/bt_ReadDeviceVersion"
                        android:layout_width="0dip"
                        android:layout_height="40dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginLeft="5dp"
                        android:layout_weight="1"
                        android:background="@drawable/color_button_selector"
                        android:text="@string/getstr"
                        android:textColor="@color/white" />
                </LinearLayout>


                <TextView
                    android:layout_width="fill_parent"
                    android:layout_height="5dp" />

                <LinearLayout
                    android:id="@+id/lineMem"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="0dip"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_weight="1"
                        android:gravity="right"
                        android:text="@string/scan_sn" />

                    <TextView
                        android:id="@+id/txt_scan_sn"
                        android:layout_width="0dip"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_weight="2"
                        android:gravity="center"
                        android:text="" />

                    <Button
                        android:id="@+id/bt_ReadScanSN"
                        android:layout_width="0dip"
                        android:layout_height="40dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginLeft="5dp"
                        android:layout_weight="1"
                        android:background="@drawable/color_button_selector"
                        android:text="@string/getstr"
                        android:textColor="@color/white" />
                </LinearLayout>






                <TextView
                    android:layout_width="fill_parent"
                    android:layout_height="5dp" />

                <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="0dip"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_weight="1"
                        android:gravity="right"
                        android:text="@string/device_sn_" />

                    <TextView
                        android:id="@+id/txt_device_sn"
                        android:layout_width="0dip"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_weight="2"
                        android:gravity="center"
                        android:text="" />

                    <Button
                        android:id="@+id/bt_ReadDeviceSN"
                        android:layout_width="0dip"
                        android:layout_height="40dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginLeft="5dp"
                        android:layout_weight="1"
                        android:background="@drawable/color_button_selector"
                        android:text="@string/getstr"
                        android:textColor="@color/white" />
                </LinearLayout>


                <TextView
                    android:layout_width="fill_parent"
                    android:layout_height="5dp" />

                <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="0dip"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_weight="1"
                        android:gravity="right"
                        android:text="RFID SN：" />

                    <TextView
                        android:id="@+id/txt_rfid_sn"
                        android:layout_width="0dip"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_weight="2"
                        android:gravity="center"
                        android:text="" />

                    <Button
                        android:id="@+id/bt_ReadRfidSN"
                        android:layout_width="0dip"
                        android:layout_height="40dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginLeft="5dp"
                        android:layout_weight="1"
                        android:background="@drawable/color_button_selector"
                        android:text="@string/getstr"
                        android:textColor="@color/white" />
                </LinearLayout>




                <TextView
                    android:layout_width="fill_parent"
                    android:layout_height="5dp" />

                <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="0dip"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_weight="1"
                        android:gravity="right"
                        android:text="@string/battery_level_" />

                    <TextView
                        android:id="@+id/txt_battery_value"
                        android:layout_width="0dip"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_weight="2"
                        android:gravity="center"
                        android:text="" />

                    <Button
                        android:id="@+id/bt_ReadBatteryValue"
                        android:layout_width="0dip"
                        android:layout_height="40dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginLeft="5dp"
                        android:layout_weight="1"
                        android:background="@drawable/color_button_selector"
                        android:text="@string/getstr"
                        android:textColor="@color/white" />
                </LinearLayout>


                <TextView
                    android:layout_width="fill_parent"
                    android:layout_height="5dp" />

                <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="0dip"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_weight="1"
                        android:gravity="right"
                        android:text="@string/ischange_status_" />

                    <TextView
                        android:id="@+id/txt_is_change"
                        android:layout_width="0dip"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_weight="2"
                        android:gravity="center"
                        android:text="" />

                    <Button
                        android:id="@+id/bt_ReadIsChange"
                        android:layout_width="0dip"
                        android:layout_height="40dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginLeft="5dp"
                        android:layout_weight="1"
                        android:background="@drawable/color_button_selector"
                        android:text="@string/getstr"
                        android:textColor="@color/white" />
                </LinearLayout>



                <TextView
                    android:layout_width="fill_parent"
                    android:layout_height="5dp" />


                <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="0dip"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_weight="1"
                        android:gravity="right"
                        android:text="@string/mode" />

                    <TextView
                        android:id="@+id/txt_mode"
                        android:layout_width="0dip"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_weight="2"
                        android:gravity="center"
                        android:text="" />

                    <Button
                        android:id="@+id/bt_mode"
                        android:layout_width="0dip"
                        android:layout_height="40dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginLeft="5dp"
                        android:layout_weight="1"
                        android:background="@drawable/color_button_selector"
                        android:text="@string/getstr"
                        android:textColor="@color/white" />
                </LinearLayout>
                <TextView
                    android:layout_width="fill_parent"
                    android:layout_height="5dp" />
                <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="0dip"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_weight="1"
                        android:gravity="right"
                        android:text="@string/key_press_event" />

                    <TextView
                        android:id="@+id/txt_keyboard"
                        android:layout_width="0dip"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_weight="2"
                        android:gravity="center"
                        android:text="" />

                    <Button
                        android:id="@+id/bt_ReadKeyboard"
                        android:layout_width="0dip"
                        android:layout_height="40dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginLeft="5dp"
                        android:layout_weight="1"
                        android:visibility="invisible"
                        android:background="@drawable/color_button_selector"
                        android:text="@string/getstr"
                        android:textColor="@color/white" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>


</LinearLayout>
</layout>