    <!-- Inventory Mode 描述 -->
    <string name="inv_mode_battery_life_desc">Extends battery life; ideal for high power-consumption scenarios but offers average inventory performance.</string>
    <string name="inv_mode_full_inventory_desc">Reads tags as quickly as possible; suitable for most scenarios with more stable performance than Cycle, positioned between Rapid and Cycle modes.</string>
    <string name="inv_mode_rapid_repeat_desc">Quickly inventories tags with rapidly increasing duplicate counts; ideal for speed demos but less comprehensive.</string>
    <string name="inv_mode_balanced_desc">Balanced between speed and battery life; suitable for environments with stable reading conditions.</string>
    <string name="inv_mode_cycle_count_desc">Inventories all tags with no duplicate counts; suited for high-interference environments but slower on subsequent reads.</string>
    <string name="inv_mode_max_range_desc">Suitable for single-tag long-range testing.</string>
    <string name="inv_mode_custom_desc">Customize some parameters according to your needs.</string>

