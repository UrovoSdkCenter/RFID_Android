<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <!-- DataBinding 变量可以在这里定义 -->
    </data>

<LinearLayout
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:keepScreenOn="true"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/ll_scanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/card_background"
        android:orientation="vertical"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:layout_marginLeft="6dp"
        android:layout_marginRight="6dp"
        android:layout_marginTop="3dp"
        android:layout_marginBottom="3dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sled_scanner"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/main_color"
            android:layout_marginBottom="3dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="3dp">
            <TextView
                android:id="@+id/tv_scanner_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginEnd="2dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="3dp"
            android:orientation="horizontal">
            <Button
                android:id="@+id/bt_StartDecode"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:background="@drawable/color_button_selector"
                android:text="@string/startdecode"
                android:textColor="@color/white"
                android:textSize="14sp" />
            <Button
                android:id="@+id/bt_StopDecode"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:background="@drawable/color_button_selector"
                android:text="@string/stopdecode"
                android:textColor="@color/white"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>



    <!-- Top operation area  顶部操作区 -->
    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/lightblue"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp" >

        <!-- Operation button row   操作按钮行 -->
        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/bt_refresh_all"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:background="@drawable/color_button_selector"
                android:text="@string/refresh_all"
                android:textColor="@color/white"
                android:paddingLeft="20dp"
                android:paddingRight="20dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_last_update_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="@color/grayslate" />

        </LinearLayout>

        <!-- Progress bar   进度条 -->
        <ProgressBar
            android:id="@+id/progress_loading"
            android:layout_width="fill_parent"
            android:layout_height="4dp"
            android:layout_marginTop="8dp"
            style="?android:attr/progressBarStyleHorizontal"
            android:visibility="gone" />

    </LinearLayout>

    <ScrollView
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:scrollbars="vertical"
        android:background="@color/lightgray">

        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_margin="6dp"
            android:orientation="vertical">


            <!-- 版本信息卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_background"
                android:orientation="vertical"
                android:padding="6dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/version_info"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/main_color"
                    android:layout_marginBottom="12dp" />

                <!-- MCU F/W Ver -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="3dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="@string/mcu_ver_"
                        android:textSize="14sp"
                        android:textColor="@color/black" />

                    <TextView
                        android:id="@+id/txt_ver_mcu"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="3"
                        android:text=""
                        android:textSize="14sp"
                        android:textColor="@color/grayslate"
                        android:background="@drawable/edittext_bg"
                        android:padding="8dp"
                        android:layout_marginRight="8dp" />

                    <ImageView
                        android:id="@+id/bt_ReadVerMcu"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/refresh_button_background"
                        android:src="@drawable/ic_refresh"
                        android:scaleType="center"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <!-- BLE F/W Ver -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="3dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="@string/ble_ver"
                        android:textSize="14sp"
                        android:textColor="@color/black" />

                    <TextView
                        android:id="@+id/txt_ver_ble"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="3"
                        android:text=""
                        android:textSize="14sp"
                        android:textColor="@color/grayslate"
                        android:background="@drawable/edittext_bg"
                        android:padding="8dp"
                        android:layout_marginRight="8dp" />

                    <ImageView
                        android:id="@+id/bt_ReadVerBle"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/refresh_button_background"
                        android:src="@drawable/ic_refresh"
                        android:scaleType="center"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <!-- RFID F/W Ver -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="3dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="@string/rfid_mcu_"
                        android:textSize="14sp"
                        android:textColor="@color/black" />

                    <TextView
                        android:id="@+id/txt_ver_rfid"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="3"
                        android:text=""
                        android:textSize="14sp"
                        android:textColor="@color/grayslate"
                        android:background="@drawable/edittext_bg"
                        android:padding="8dp"
                        android:layout_marginRight="8dp" />

                    <ImageView
                        android:id="@+id/bt_ReadVerRfid"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/refresh_button_background"
                        android:src="@drawable/ic_refresh"
                        android:scaleType="center"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <!-- Scanner F/W version -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="@string/scan_ver_"
                        android:textSize="14sp"
                        android:textColor="@color/black" />

                    <TextView
                        android:id="@+id/txt_scan_version"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="3"
                        android:text=""
                        android:textSize="14sp"
                        android:textColor="@color/grayslate"
                        android:background="@drawable/edittext_bg"
                        android:padding="8dp"
                        android:layout_marginRight="8dp" />

                    <ImageView
                        android:id="@+id/bt_ReadDeviceVersion"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/refresh_button_background"
                        android:src="@drawable/ic_refresh"
                        android:scaleType="center"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>
            </LinearLayout>

            <!-- Devide Information Card  设备信息卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_background"
                android:orientation="vertical"
                android:padding="6dp"
                android:layout_marginBottom="5dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/devices_info"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/main_color"
                    android:layout_marginBottom="3dp" />

                <!--Scanner SN   扫描SN -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="3dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="@string/scan_sn"
                        android:textSize="14sp"
                        android:textColor="@color/black" />

                    <TextView
                        android:id="@+id/txt_scan_sn"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="3"
                        android:text=""
                        android:textSize="14sp"
                        android:textColor="@color/grayslate"
                        android:background="@drawable/edittext_bg"
                        android:padding="8dp"
                        android:layout_marginRight="8dp" />

                    <ImageView
                        android:id="@+id/bt_ReadScanSN"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/refresh_button_background"
                        android:src="@drawable/ic_refresh"
                        android:scaleType="center"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <!-- Device SN   设备SN -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="3dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="@string/device_sn_"
                        android:textSize="14sp"
                        android:textColor="@color/black" />

                    <TextView
                        android:id="@+id/txt_device_sn"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="3"
                        android:text=""
                        android:textSize="14sp"
                        android:textColor="@color/grayslate"
                        android:background="@drawable/edittext_bg"
                        android:padding="8dp"
                        android:layout_marginRight="8dp" />

                    <ImageView
                        android:id="@+id/bt_ReadDeviceSN"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/refresh_button_background"
                        android:src="@drawable/ic_refresh"
                        android:scaleType="center"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <!-- RFID SN -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="RFID SN："
                        android:textSize="14sp"
                        android:textColor="@color/black" />

                    <TextView
                        android:id="@+id/txt_rfid_sn"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="3"
                        android:text=""
                        android:textSize="14sp"
                        android:textColor="@color/grayslate"
                        android:background="@drawable/edittext_bg"
                        android:padding="8dp"
                        android:layout_marginRight="8dp" />

                    <ImageView
                        android:id="@+id/bt_ReadRfidSN"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/refresh_button_background"
                        android:src="@drawable/ic_refresh"
                        android:scaleType="center"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>
            </LinearLayout>

            <!-- Power management card    电源管理卡片 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_power"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="6dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="@string/power_management"
                        android:textColor="@color/main_color"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <!-- Shutdown Time Row  关机时间行 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/power_off_time"
                            android:textColor="#666666"
                            android:textSize="14sp" />

                        <Spinner
                            android:id="@+id/power_off_spinner"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_spinner" />

                    </LinearLayout>

                    <!-- Hibernation time period  休眠时间行 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/xm_time"
                            android:textColor="#666666"
                            android:textSize="14sp" />

                        <Spinner
                            android:id="@+id/sleep_spinner"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_spinner" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Buzzer Volume Setting Card  蜂鸣器音量设置卡片 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_beeper_volume"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="@string/beeper_volume_setting"
                        android:textColor="@color/main_color"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <RadioGroup
                        android:id="@+id/rg_beeper_volume"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <RadioButton
                            android:id="@+id/rb_sound_off"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="3dp"
                            android:text="@string/sound_off"
                            android:textColor="#333333"
                            android:textSize="14sp" />

                        <RadioButton
                            android:id="@+id/rb_low_volume"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="3dp"
                            android:text="@string/low_volume"
                            android:textColor="#333333"
                            android:textSize="14sp" />

                        <RadioButton
                            android:id="@+id/rb_high_volume"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/high_volume"
                            android:checked="true"
                            android:textColor="#333333"
                            android:textSize="14sp" />

                    </RadioGroup>

                </LinearLayout>

            </androidx.cardview.widget.CardView>



        </LinearLayout>
    </ScrollView>

</LinearLayout>
</layout>