<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <data>
        <!-- DataBinding 变量可以在这里定义 -->
    </data>

<ScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="3dp"
    android:background="#f5f5f5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Tag Info Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:paddingLeft="5dp"
            android:paddingTop="5dp"
            android:layout_marginBottom="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tag_info"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/main_color"
                android:layout_marginBottom="2dp" />

            <!-- Tag Info：选择EPC + 输入框合并为一行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="2dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingLeft="5dp"
                    android:paddingRight="4dp"
                    android:text="@string/select_epc"
                    android:textSize="14sp" />
                <ImageButton
                    android:id="@+id/btn_epc_picker"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_arrow_down"
                    android:scaleType="fitCenter"
                    android:contentDescription="@string/select_epc" />
                <EditText
                    android:id="@+id/epc_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:background="#f0f0f0"
                    android:padding="2dp"
                    android:text="" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="@string/tid"
                    android:textSize="14sp"
                    android:gravity="end"
                    android:layout_marginEnd="8dp" />
                <TextView
                    android:id="@+id/tid_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:background="#f0f0f0"
                    android:padding="8dp"
                    android:text="" />
            </LinearLayout>
        </LinearLayout>

        <!-- Read/Write Operations Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="3dp"
            android:layout_marginBottom="5dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/read_write_operations"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/main_color" />

                <CheckBox
                    android:id="@+id/cb_ascii"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ASCII"
                    android:textSize="14sp"
                    android:textColor="@color/black"
                    android:layout_marginRight="5dp"/>

            </LinearLayout>

            <!-- Access Password -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="3dp">
                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="@string/pwdstr"
                    android:textSize="14sp"
                    android:gravity="end"
                    android:layout_marginEnd="8dp"
                    android:layout_gravity="center_vertical" />
                <EditText
                    android:id="@+id/et_pwd"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_weight="1"
                    android:hint="00000000"
                    android:textSize="14sp"
                    android:padding="8dp"
                    android:background="@drawable/edittext_bg" />
            </LinearLayout>

            <!-- Memory Bank -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="3dp">
                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="@string/bankid"
                    android:textSize="14sp"
                    android:gravity="end"
                    android:layout_marginEnd="8dp"
                    android:layout_gravity="center_vertical" />
                <Spinner
                    android:id="@+id/mem_spinner"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_weight="1" />
            </LinearLayout>

            <!-- Word Pointer -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="3dp">
                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="@string/memptr"
                    android:textSize="14sp"
                    android:gravity="end"
                    android:layout_marginEnd="8dp"
                    android:layout_gravity="center_vertical" />
                <EditText
                    android:id="@+id/et_wordptr"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_weight="1"
                    android:inputType="numberSigned"
                    android:text="2"
                    android:textSize="14sp"
                    android:padding="8dp"
                    android:background="@drawable/edittext_bg" />
            </LinearLayout>

            <!-- Length -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="3dp">
                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="@string/memlen"
                    android:textSize="14sp"
                    android:gravity="end"
                    android:layout_marginEnd="8dp"
                    android:layout_gravity="center_vertical" />
                <EditText
                    android:id="@+id/et_length"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_weight="1"
                    android:inputType="numberSigned"
                    android:text="6"
                    android:textSize="14sp"
                    android:padding="8dp"
                    android:background="@drawable/edittext_bg" />
            </LinearLayout>

            <!-- Write Data -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="3dp">
                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="@string/writestr"
                    android:textSize="14sp"
                    android:gravity="end"
                    android:layout_marginEnd="8dp"
                    android:layout_gravity="top"
                    android:layout_marginTop="3dp" />
                <EditText
                    android:id="@+id/et_content_6c"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:inputType="textMultiLine"
                    android:hint="@string/write_input_hex"
                    android:digits="1234567890ABCDEFabcdef"
                    android:textSize="14sp"
                    android:padding="8dp"
                    android:gravity="top"
                    android:background="@drawable/edittext_bg" />
            </LinearLayout>

            <!-- Read Data -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="5dp">
                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="@string/readstr"
                    android:textSize="14sp"
                    android:gravity="end"
                    android:layout_marginEnd="8dp"
                    android:layout_gravity="top"
                    android:layout_marginTop="3dp" />
                <EditText
                    android:id="@+id/et_read_6c"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:inputType="textMultiLine"
                    android:textSize="14sp"
                    android:padding="3dp"
                    android:gravity="top"
                    android:background="@drawable/edittext_bg"
                    android:focusable="false" />
            </LinearLayout>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <Button
                    android:id="@+id/button_read_6c"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/color_button_selector"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:text="@string/butnread" />
                <Button
                    android:id="@+id/button_write_6c"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/color_button_selector"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:text="@string/butnwrite" />
                <Button
                    android:id="@+id/button_write_epc"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/color_button_selector"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:text="@string/butnwriteepc" />
            </LinearLayout>
        </LinearLayout>

        <!-- Lock Operations Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="3dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/lock_operations"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/main_color"
                android:layout_marginBottom="3dp" />

            <!-- Lock Memory -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="3dp">
                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="@string/tvLockMem"
                    android:textSize="14sp"
                    android:gravity="end"
                    android:layout_marginEnd="8dp"
                    android:layout_gravity="center_vertical" />
                <Spinner
                    android:id="@+id/lockmem_spinner"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_weight="1" />
            </LinearLayout>

            <!-- Lock Type -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="3dp">
                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="@string/tvLockType"
                    android:textSize="14sp"
                    android:gravity="end"
                    android:layout_marginEnd="8dp"
                    android:layout_gravity="center_vertical" />
                <Spinner
                    android:id="@+id/locktype_spinner"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_weight="1" />
            </LinearLayout>

            <!-- U9 Checkbox and Lock Button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <CheckBox
                    android:id="@+id/checku9"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="U9"
                    android:textSize="14sp" />
                <Button
                    android:id="@+id/button_lock"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_weight="2"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/color_button_selector"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:text="@string/btlock" />
            </LinearLayout>
        </LinearLayout>

        <!-- Kill Operations Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="3dp"
            android:layout_marginBottom="5dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/kill_operations"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/main_color"
                android:layout_marginBottom="3dp" />

            <!-- Kill Password -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="3dp">
                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="@string/tvKillPwd"
                    android:textSize="14sp"
                    android:gravity="end"
                    android:layout_marginEnd="8dp"
                    android:layout_gravity="center_vertical" />
                <EditText
                    android:id="@+id/et_kwd"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_weight="1"
                    android:text="12345678"
                    android:textSize="14sp"
                    android:padding="3dp"
                    android:background="@drawable/edittext_bg" />
            </LinearLayout>

            <!-- Kill Button -->
            <Button
                android:id="@+id/button_kill"
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:background="@drawable/color_button_selector"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:text="@string/btKill" />
        </LinearLayout>


        <!-- Erase Button (Hidden by default) -->
        <Button
            android:id="@+id/button_erase"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/color_button_selector"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:text="@string/btn_erase"
            android:visibility="gone" />

        <!-- Warning Note -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#cc0000"
            android:textSize="12sp"
            android:padding="3dp"
            android:text="@string/noteStr" />

    </LinearLayout>
</ScrollView>
</layout>